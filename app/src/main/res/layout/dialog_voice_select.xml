<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择角色声音"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 预设和自定义音色容器（动态添加自定义音色到此 LinearLayout） -->
    <LinearLayout
        android:id="@+id/llVoiceOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 男声 -->
        <LinearLayout
            android:id="@+id/optionMale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_option_voice"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/voice"
                android:background="@null"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="男声"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- 女声 -->
        <LinearLayout
            android:id="@+id/optionFemale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_option_voice"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/voice"
                android:background="@null"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="女声"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- 自定义音色将动态插入到此处（在“新建音色”之前） -->
        <!-- 新建音色 -->
        <LinearLayout
            android:id="@+id/optionNew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_option_voice"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_add"
                android:background="@null"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="新建音色"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginStart="12dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>